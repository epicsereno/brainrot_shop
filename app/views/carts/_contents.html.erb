<% if cart.empty? %>
  <div class="rounded-xl border border-zinc-800 bg-zinc-900 p-8 text-center">
    <p class="text-zinc-400">Your cart is empty. Go get some drip. 💀</p>
    <%= link_to "Browse the shop", products_path, class: "mt-4 inline-block rounded-lg bg-fuchsia-600 px-5 py-2.5 font-semibold text-white hover:bg-fuchsia-500" %>
  </div>
<% else %>
  <div class="space-y-3">
    <% cart.line_items.each do |item| %>
      <div class="flex items-center gap-4 rounded-xl border border-zinc-800 bg-zinc-900 p-4">
        <div class="h-16 w-16 flex-shrink-0 overflow-hidden rounded-lg bg-zinc-800">
          <% if item.variant.product.image.attached? %>
            <%= image_tag item.variant.product.image, class: "h-full w-full object-cover", alt: item.variant.product.title %>
          <% else %>
            <div class="flex h-full w-full items-center justify-center text-2xl">🧠</div>
          <% end %>
        </div>

        <div class="min-w-0 flex-1">
          <p class="truncate font-semibold"><%= item.variant.product.title %></p>
          <p class="text-sm text-zinc-400"><%= item.variant.label %> · <%= number_to_currency(item.variant.price) %></p>
        </div>

        <%= form_with url: cart_item_path(item.variant.id), method: :patch, class: "flex items-center gap-2" do %>
          <%= number_field_tag :quantity, item.quantity, min: 1, max: 99,
                onchange: "this.form.requestSubmit()",
                class: "w-16 rounded-lg border border-zinc-700 bg-zinc-900 px-2 py-1.5 text-center text-zinc-100 focus:border-fuchsia-500 focus:outline-none" %>
        <% end %>

        <p class="w-20 text-right font-bold"><%= number_to_currency(item.subtotal) %></p>

        <%= button_to cart_item_path(item.variant.id), method: :delete,
              class: "rounded-lg p-2 text-zinc-500 hover:bg-zinc-800 hover:text-red-400", title: "Remove" do %>
          ✕
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="mt-6 flex items-center justify-between rounded-xl border border-zinc-800 bg-zinc-900 p-4">
    <span class="text-lg font-semibold text-zinc-300">Total</span>
    <span class="text-2xl font-black text-fuchsia-400"><%= number_to_currency(cart.total) %></span>
  </div>

  <button disabled
          class="mt-4 w-full cursor-not-allowed rounded-lg bg-zinc-800 px-6 py-3 font-bold text-zinc-500"
          title="Checkout ships in the payments milestone">
    Checkout (coming soon) →
  </button>
<% end %>
