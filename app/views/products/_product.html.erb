<%= link_to product_path(product), class: "group block overflow-hidden rounded-xl border border-zinc-800 bg-zinc-900 transition hover:border-fuchsia-600/60" do %>
  <div class="aspect-square overflow-hidden bg-zinc-800">
    <% if product.image.attached? %>
      <%= image_tag product.image, class: "h-full w-full object-cover transition group-hover:scale-105", alt: product.title %>
    <% else %>
      <div class="flex h-full w-full items-center justify-center text-5xl">🧠</div>
    <% end %>
  </div>
  <div class="p-3">
    <p class="text-xs uppercase tracking-wide text-zinc-500"><%= product.category %></p>
    <h3 class="mt-0.5 truncate font-semibold"><%= product.title %></h3>
    <p class="mt-1 font-bold text-fuchsia-400"><%= number_to_currency(product.base_price) %></p>
  </div>
<% end %>
