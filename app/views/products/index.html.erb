<% content_for :title, "Brainrot Shop — Get the Drip" %>

<section class="mb-8">
  <h1 class="text-3xl font-black sm:text-4xl">
    Wear the <span class="bg-gradient-to-r from-fuchsia-500 to-cyan-400 bg-clip-text text-transparent">brainrot</span>.
  </h1>
  <p class="mt-2 max-w-2xl text-zinc-400">
    Chaotic, meme-ready, print-on-demand merch. Tees, hoodies, hats, posters &amp; stickers.
  </p>
</section>

<nav class="mb-6 flex flex-wrap gap-2">
  <%= link_to "All", products_path,
        class: "rounded-full px-4 py-1.5 text-sm font-semibold #{params[:category].blank? ? 'bg-fuchsia-600 text-white' : 'bg-zinc-800 text-zinc-300 hover:bg-zinc-700'}" %>
  <% @categories.each do |category| %>
    <%= link_to category.titleize.pluralize, products_path(category: category),
          class: "rounded-full px-4 py-1.5 text-sm font-semibold #{params[:category] == category ? 'bg-fuchsia-600 text-white' : 'bg-zinc-800 text-zinc-300 hover:bg-zinc-700'}" %>
  <% end %>
</nav>

<% if @products.any? %>
  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
    <%= render @products %>
  </div>
<% else %>
  <p class="rounded-xl border border-zinc-800 bg-zinc-900 p-8 text-center text-zinc-400">
    No drip here yet. Check back soon. 💀
  </p>
<% end %>
