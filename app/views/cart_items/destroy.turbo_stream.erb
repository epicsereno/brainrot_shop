<%= turbo_stream.replace "cart_badge" do %>
  <%= render "shared/cart_badge", cart: @cart %>
<% end %>

<%= turbo_stream.replace "flash_messages" do %>
  <%= render "shared/flash", notice: @notice, alert: nil %>
<% end %>

<%= turbo_stream.replace "cart_contents" do %>
  <%= render "carts/contents", cart: @cart %>
<% end %>
